# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=8081

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Frontend base URL — where email-template HTML (their "UI") is served from.
# The backend fetches /email-templates/*.html here and fills in values.
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/petcare?schema=public"

# ──────────────────────────────────────────────
# JWT Auth
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt cost factor
BCRYPT_SALT_ROUNDS=10

# ──────────────────────────────────────────────
# Firebase Cloud Messaging (push notifications) — OPTIONAL
# Leave blank to disable push; chat still works in real time via Socket.IO
# plus in-app/system notifications.
# From your Firebase service-account JSON (Project settings → Service accounts).
# ──────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal "\n" sequences from the JSON; they are converted at runtime.
FIREBASE_PRIVATE_KEY=

# ──────────────────────────────────────────────
# WhatsApp OTP (phone verification) — OPTIONAL
# Leave WHATSAPP_PROVIDER blank to run the DEV STUB: the OTP is logged to the
# server console and returned to the client as `devCode` (dev only) so the flow
# works without a provider. Set a provider + its creds to send real messages.
# ──────────────────────────────────────────────
# Provider: "meta" (WhatsApp Cloud API) or "twilio". Blank = dev stub.
WHATSAPP_PROVIDER=

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# OTP behaviour (optional — these are the defaults)
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SEC=30

# ──────────────────────────────────────────────
# Google OAuth (Sign in with Google) — OPTIONAL
# Leave blank to disable Google sign-in. Create an OAuth 2.0 "Web application"
# client in the Google Cloud console; the Client ID below must match the one the
# frontend uses (VITE_GOOGLE_CLIENT_ID). No client secret is needed server-side.
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=1063499539647-fukuss168drplrco2003g4jbr12qr5cr.apps.googleusercontent.com

# ──────────────────────────────────────────────
# Email OTP (SMTP, e.g. Mailtrap) — OPTIONAL
# Leave blank to run the DEV STUB (code logged to console / returned as devCode).
# Mailtrap Sandbox: host sandbox.smtp.mailtrap.io, port 2525, user/pass from inbox.
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=bvkjosi03@gmail.com
MAIL_PASS=geni auua pjuw jzll
MAIL_FROM=PetCare <no-reply@petcare.app>
