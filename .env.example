# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=8081

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/petcare?schema=public"

# ──────────────────────────────────────────────
# JWT Auth
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt cost factor
BCRYPT_SALT_ROUNDS=10

# ──────────────────────────────────────────────
# Firebase Cloud Messaging (push notifications) — OPTIONAL
# Leave blank to disable push; chat still works in real time via Socket.IO
# plus in-app/system notifications.
# From your Firebase service-account JSON (Project settings → Service accounts).
# ──────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal "\n" sequences from the JSON; they are converted at runtime.
FIREBASE_PRIVATE_KEY=
